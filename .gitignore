# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# runtime uploads (user-generated content, not source)
/public/uploads/*
!/public/uploads/.gitkeep

# unused/leftover 3D scratch assets (not referenced by the app)
/*.glb
/public/Velociraptor.glb
/public/models/retro-computer.glb

# debug screenshots and design-reference scratch dirs
/*.png
/.playwright-mcp/
/my-project-design/
/_vt/

# graphify tool cache/output
/.graphify_*
/src/graphify-out/

# local agent/skill tooling caches
/.agents/
/.claude/skills/
